# Environment variables for Docker Compose
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control!

# RabbitMQ Configuration
RABBITMQ_USER=cmsadmin
RABBITMQ_PASSWORD=CmsSecurePassword123!
RABBITMQ_VHOST=/cms

# MongoDB Configuration
MONGO_USER=admin
MONGO_PASSWORD=MongoSecurePassword123!

# JWT Configuration (Generate a strong key in production!)
JWT_SECRET_KEY=YourSuperSecretKeyThatIsAtLeast32CharactersLongForProduction!
JWT_ISSUER=CMS-API
JWT_AUDIENCE=CMS-Clients

# ASP.NET Environment
ASPNETCORE_ENVIRONMENT=Production

# Optional: For development
# ASPNETCORE_ENVIRONMENT=Development
